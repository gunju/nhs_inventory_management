APP_NAME=NHS Inventory Intelligence Copilot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1

# Database (use docker service name 'db' inside containers)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/nhs_inventory

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth — CHANGE THIS IN PRODUCTION
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_256_BIT_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM — set to 'openai' and add key to use real LLM
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=mock
EMBEDDING_DIM=1536

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads

# pgvector
ENABLE_PGVECTOR=true

# Celery
ENABLE_CELERY=true

# Seed on startup (dev only)
SEED_ON_STARTUP=false
